var mode='tutor', activeFilter='all', showFilter='all';
var session=[], idx=0, selected=null, submitted=false;
var timerInterval=null, timeLeft=90;
var results=[];
var flagged=new Set();
var answered=new Map();

function setMode(m){
  mode=m;
  document.getElementById('tutorBtn').classList.toggle('active',m==='tutor');
  document.getElementById('timedBtn').classList.toggle('active',m==='timed');
}
function toggleFilter(btn,val){
  activeFilter=val;
  document.querySelectorAll('.filter-bar')[0].querySelectorAll('.fbtn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
}
function toggleShow(btn,val){
  showFilter=val;
  document.querySelectorAll('.filter-bar')[1].querySelectorAll('.fbtn').forEach(function(b){b.classList.remove('on');});
  btn.classList.add('on');
}
function getFiltered(){
  return QS.filter(function(q){
    if(activeFilter!=='all' && q.lec!==activeFilter) return false;
    if(showFilter==='unanswered' && answered.has(q.id)) return false;
    if(showFilter==='flagged' && !flagged.has(q.id)) return false;
    if(showFilter==='wrong' && (!answered.has(q.id)||answered.get(q.id).correct)) return false;
    return true;
  });
}
function startQuiz(){
  var pool=getFiltered();
  if(!pool.length){alert('No questions match your filters.');return;}
  session=pool.slice().sort(function(){return Math.random()-.5;});
  idx=0; results=[];
  document.getElementById('dashboard').style.display='none';
  document.getElementById('quiz').style.display='block';
  document.getElementById('results').style.display='none';
  document.getElementById('review').style.display='none';
  renderQ();
}
function renderQ(){
  var q=session[idx];
  selected=null; submitted=false;
  var sb=document.getElementById('submitBtn');
  sb.disabled=true; sb.textContent='Submit Answer'; sb.onclick=submitAnswer;
  document.getElementById('expCard').classList.remove('show');
  document.getElementById('qnum').textContent='Q '+(idx+1)+' / '+session.length;
  document.getElementById('qpfill').style.width=(((idx+1)/session.length)*100)+'%';
  var trapTag=q.trap?'<span class="tag tag-trap">Trap</span>':'';
  document.getElementById('qtags').innerHTML=
    '<span class="tag tag-lec">'+q.lec+'</span><span class="tag tag-top">'+q.topic+'</span>'+trapTag+
    '<button class="flag-btn" onclick="toggleFlag('+q.id+')">'+(flagged.has(q.id)?'⚑':'⚐')+'</button>';
  document.getElementById('qtext').textContent=q.stem;
  var letters=['A','B','C','D','E'];
  document.getElementById('choices').innerHTML=q.choices.map(function(c,i){
    return '<div class="choice" id="ch'+i+'" onclick="selectChoice('+i+')"><span class="letter">'+letters[i]+'</span><span class="ctext">'+c+'</span></div>';
  }).join('');
  if(mode==='timed'){
    timeLeft=90;
    document.getElementById('timerBox').style.display='block';
    updateTimer();
    if(timerInterval) clearInterval(timerInterval);
    timerInterval=setInterval(function(){
      timeLeft--;
      updateTimer();
      if(timeLeft<=0){clearInterval(timerInterval);if(!submitted){selected=-1;submitAnswer();}}
    },1000);
  } else {
    document.getElementById('timerBox').style.display='none';
    if(timerInterval){clearInterval(timerInterval);timerInterval=null;}
  }
}
function updateTimer(){
  var el=document.getElementById('timerBox');
  var m=Math.floor(timeLeft/60), s=timeLeft%60;
  el.textContent=m+':'+(s<10?'0':'')+s;
  el.classList.toggle('warn',timeLeft<=20);
}
function selectChoice(i){
  if(submitted) return;
  selected=i;
  document.querySelectorAll('.choice').forEach(function(c,j){c.classList.toggle('selected',j===i);});
  document.getElementById('submitBtn').disabled=false;
}
function toggleFlag(id){
  if(flagged.has(id)) flagged.delete(id); else flagged.add(id);
  var fb=document.querySelector('.flag-btn');
  document.getElementById('qtags').querySelector('.flag-btn').textContent=flagged.has(id)?'⚑':'⚐';
  document.getElementById('s-flagged').textContent=flagged.size;
}
function submitAnswer(){
  if(timerInterval) clearInterval(timerInterval);
  var q=session[idx];
  submitted=true;
  var correct=(selected===q.correct);
  answered.set(q.id,{correct:correct,selected:selected});
  results.push({q:q,selected:selected,correct:correct});
  updateStats();
  var letters=['A','B','C','D','E'];
  document.querySelectorAll('.choice').forEach(function(c,i){
    c.classList.add('disabled');
    if(i===q.correct) c.classList.add(selected===-1?'show-correct':'correct');
    else if(i===selected && !correct) c.classList.add('wrong');
  });
  if(mode==='tutor') showExp(q,correct);
  var sb=document.getElementById('submitBtn');
  sb.textContent='Next Question \u2192'; sb.disabled=false; sb.onclick=nextQ;
}
function showExp(q,correct){
  var letters=['A','B','C','D','E'];
  document.getElementById('expCard').classList.add('show');
  var er=document.getElementById('expResult');
  er.className='exp-result '+(correct?'right':'wrong');
  er.textContent=correct?'Correct!':'Incorrect \u2014 '+letters[q.correct]+' is correct';
  document.getElementById('expWhy').textContent=q.why;
  document.getElementById('trapTxt').textContent=q.trapText;
  var wwHTML='<div class="exp-sect">Why each wrong answer is wrong</div>';
  q.choices.forEach(function(c,i){
    if(i===q.correct) return;
    wwHTML+='<div class="ww-item"><span class="ww-ltr">'+letters[i]+'.</span><span class="ww-txt">'+q.ww[i]+'</span></div>';
  });
  document.getElementById('expWW').innerHTML=wwHTML;
}
function nextQ(){
  idx++;
  if(idx>=session.length){showResults();return;}
  renderQ();
  document.getElementById('expCard').classList.remove('show');
  window.scrollTo(0,0);
}
function updateStats(){
  var done=answered.size;
  var correct=0; answered.forEach(function(v){if(v.correct) correct++;});
  document.getElementById('s-done').textContent=done;
  document.getElementById('s-correct').textContent=correct;
}
function showResults(){
  document.getElementById('quiz').style.display='none';
  var total=results.length;
  var correct=results.filter(function(r){return r.correct;}).length;
  var pct=Math.round((correct/total)*100);
  var topics={};
  results.forEach(function(r){
    var k=r.q.lec;
    if(!topics[k]) topics[k]={c:0,t:0};
    topics[k].t++;
    if(r.correct) topics[k].c++;
  });
  var topicHTML=Object.keys(topics).map(function(name){
    var c=topics[name].c, t=topics[name].t;
    var p=Math.round((c/t)*100);
    var col=p>=80?'#059669':p>=60?'#D97706':'#DC2626';
    return '<div class="topic-row"><span class="topic-name">'+name+'</span>'+
      '<div class="topic-bar-bg"><div class="topic-bar" style="width:'+p+'%;background:'+col+'"></div></div>'+
      '<span class="topic-pct">'+c+'/'+t+'</span></div>';
  }).join('');
  var emoji=pct>=80?'🏆':pct>=60?'📈':'📚';
  var msg=pct>=80?'Excellent work!':pct>=60?'Good — review the misses!':'Keep at it — you\'ve got this!';
  document.getElementById('results').style.display='block';
  document.getElementById('results').innerHTML=
    '<div class="res-hero"><div class="res-score">'+pct+'%</div><div style="font-size:20px;margin:4px 0">'+emoji+'</div>'+
    '<div class="res-sub">'+correct+' / '+total+' correct &nbsp;&middot;&nbsp; '+msg+'</div></div>'+
    '<div class="res-grid">'+
    '<div class="res-card"><div class="res-card-title">By Lecture</div>'+topicHTML+'</div>'+
    '<div class="res-card"><div class="res-card-title">Session Summary</div>'+
    '<div class="topic-row"><span class="topic-name">Total</span><span class="topic-pct">'+total+'</span></div>'+
    '<div class="topic-row"><span class="topic-name">Correct</span><span class="topic-pct" style="color:#059669">'+correct+'</span></div>'+
    '<div class="topic-row"><span class="topic-name">Incorrect</span><span class="topic-pct" style="color:#DC2626">'+(total-correct)+'</span></div>'+
    '<div class="topic-row"><span class="topic-name">Flagged</span><span class="topic-pct" style="color:#F97316">'+flagged.size+'</span></div>'+
    '<div class="topic-row"><span class="topic-name">Mode</span><span class="topic-pct">'+(mode==='tutor'?'Tutor':'Timed')+'</span></div>'+
    '</div></div>'+
    '<button class="review-btn" onclick="showReview()">Review All Questions</button>'+
    '<button class="restart-btn" onclick="backToDash()">Back to Dashboard</button>';
}
function showReview(){
  document.getElementById('results').style.display='none';
  document.getElementById('review').style.display='block';
  var letters=['A','B','C','D','E'];
  var html='<div style="font-size:13px;font-weight:700;margin-bottom:12px;">Question Review</div>';
  results.forEach(function(r,i){
    var q=r.q;
    html+='<div class="rev-q '+(r.correct?'cq':'wq')+'">'+
      '<div class="rev-tag '+(r.correct?'right':'wrong')+'">'+(r.correct?'CORRECT':'INCORRECT')+' &middot; Q'+(i+1)+' &middot; '+q.lec+' &middot; '+q.topic+'</div>'+
      '<div class="rev-stem">'+q.stem.substring(0,160)+'...</div>'+
      '<div class="rev-ans">Correct: ('+letters[q.correct]+') '+q.choices[q.correct]+'</div>'+
      (!r.correct && r.selected>=0?'<div class="rev-wrong">Your answer: ('+letters[r.selected]+') '+q.choices[r.selected]+'</div>':'')+
      (!r.correct && r.selected===-1?'<div class="rev-wrong">Time expired — unanswered</div>':'')+
      '</div>';
  });
  html+='<button class="back-btn" onclick="backToResults()">Back to Results</button>';
  document.getElementById('review').innerHTML=html;
}
function backToResults(){
  document.getElementById('review').style.display='none';
  document.getElementById('results').style.display='block';
}
function backToDash(){
  document.getElementById('results').style.display='none';
  document.getElementById('quiz').style.display='none';
  document.getElementById('dashboard').style.display='block';
  updateStats();
}
</script>
</body></html>
